# ─── Chat (Ollama) ───────────────────────────────────────────────
# Base URL for Ollama API (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Model to use (default: llama3.2). Others: mistral, codellama, llama2…
OLLAMA_MODEL=llama3.2

# ─── Pledge flow ─────────────────────────────────────────────────
# Public base URL of the site (used for Stripe redirects + email links).
# Local dev: http://localhost:3000  ·  Prod: https://askmikeai.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe — start with TEST keys (sk_test_…), swap to live when ready.
STRIPE_SECRET_KEY=sk_test_xxx

# Secret used to sign email-verification links (any long random string).
# Generate one:  openssl rand -hex 32
PLEDGE_SECRET=change-me-to-a-long-random-string

# Resend — sends the email-verification link after a pledge.
RESEND_API_KEY=re_xxx
# Verified sender. For quick testing you can use Resend's sandbox address:
RESEND_FROM_EMAIL=AskMikeAI <onboarding@resend.dev>

# Calendly event used for the "book a Zoom" step after verification.
# Configure this event type in Calendly to auto-create Zoom meetings.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/askmikeai/30min?hide_gdpr_banner=1&background_color=ffffff&text_color=1f2937&primary_color=db2777
